APP_NAME="Smart Drug Interaction and Safety API"
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/drug_safety
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# Firebase Admin SDK — path to service account JSON OR inline JSON string
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
SEED_ADMIN_PHONE=+15555550100
SEED_ADMIN_FULL_NAME=System Admin
